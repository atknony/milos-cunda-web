---
/**
 * Milos Cunda — Main Layout
 * Master wrapper: dynamic lang, SEO meta, JSON-LD, hreflang, ViewTransitions.
 */

import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

import { getLangFromUrl, useTranslations, getAlternateUrls } from "../i18n/utils";
import { languages, type Lang } from "../i18n/ui";
import {
  generateHotelSchema,
  generateBreadcrumbSchema,
  generateWebSiteSchema,
  type BreadcrumbItem,
} from "../lib/schema";

/* ─── Props ─── */
interface Props {
  /** Page title — overrides the default meta.title */
  title?: string;
  /** Meta description — overrides the default meta.description */
  description?: string;
  /** Open Graph image path (relative to site root) */
  ogImage?: string;
  /** Canonical URL override */
  canonical?: string;
  /** Breadcrumb trail for structured data */
  breadcrumbs?: BreadcrumbItem[];
  /** Additional JSON-LD schemas (room-specific, article, etc.) */
  additionalSchemas?: Record<string, unknown>[];
  /** Page type for OG tags */
  ogType?: "website" | "article";
  /** Disable the default Hotel JSON-LD (for non-hotel pages) */
  noHotelSchema?: boolean;
}

const {
  title,
  description,
  ogImage = "/images/og/default.jpg",
  canonical,
  breadcrumbs,
  additionalSchemas = [],
  ogType = "website",
  noHotelSchema = false,
} = Astro.props;

/* ─── Language Setup ─── */
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pageTitle = title ?? t("meta.title");
const pageDescription = description ?? t("meta.description");

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://miloscunda.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

/* ─── Hreflang Alternates ─── */
const alternates = getAlternateUrls(Astro.url, siteUrl);

/* ─── JSON-LD Assembly ─── */
const schemas: Record<string, unknown>[] = [];

// Always include WebSite schema
schemas.push(generateWebSiteSchema(lang));

// Include Hotel schema unless explicitly disabled
if (!noHotelSchema) {
  schemas.push(generateHotelSchema(lang));
}

// Include breadcrumbs if provided
if (breadcrumbs && breadcrumbs.length > 0) {
  schemas.push(generateBreadcrumbSchema(breadcrumbs));
}

// Merge any page-specific schemas
schemas.push(...additionalSchemas);

/* ─── Text Direction ─── */
const dir = "ltr"; // All three languages (tr, en, el) are LTR
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- ─── Primary Meta ─── -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Milos Cunda" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- ─── Hreflang Tags ─── -->
    {alternates.map(({ lang: altLang, href }) => (
      <link rel="alternate" hreflang={altLang} href={href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternates.find((a) => a.lang === "tr")?.href}
    />

    <!-- ─── Open Graph ─── -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Milos Cunda" />
    <meta property="og:locale" content={lang === "tr" ? "tr_TR" : lang === "el" ? "el_GR" : "en_US"} />

    <!-- ─── Twitter Card ─── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- ─── Geo Meta (for local SEO) ─── -->
    <meta name="geo.region" content="TR-10" />
    <meta name="geo.placename" content="Cunda Island, Ayvalık" />
    <meta name="geo.position" content="39.3275;26.6927" />
    <meta name="ICBM" content="39.3275, 26.6927" />

    <!-- ─── Favicon ─── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf9f7" />

    <!-- ─── Font Preloads ─── -->
    <link
      rel="preload"
      href="/fonts/PlayfairDisplay-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/DMSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- ─── JSON-LD Structured Data ─── -->
    {schemas.map((schema) => (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema, null, 0)}
      />
    ))}

    <!-- ─── View Transitions ─── -->
    <ViewTransitions />
  </head>

  <body
    class="min-h-screen bg-stone-50 text-stone-800 font-sans antialiased
           selection:bg-aegean-200 selection:text-aegean-900"
  >
    <!-- Skip to Content (Accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4
             focus:z-[999] focus:bg-stone-900 focus:text-stone-50
             focus:px-4 focus:py-2 focus:rounded-sm focus:text-sm"
    >
      {t("a11y.skipToContent")}
    </a>

    <!-- Header Slot — to be filled by Header component -->
    <slot name="header" />

    <!-- Main Content -->
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>

    <!-- Footer Slot — to be filled by Footer component -->
    <slot name="footer" />

    <!-- Reveal-on-scroll observer (minimal client JS) -->
    <script>
      document.addEventListener("astro:page-load", () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
        );

        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
