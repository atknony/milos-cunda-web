---
/**
 * Milos Cunda — Footer
 *
 * Three-column layout: Brand + Contact | Navigation | Social.
 * Bottom bar with legal text and privacy link.
 * Geo-coordinates and structured address for local SEO.
 */

import { getLangFromUrl, useTranslations, getLocalizedPath, getHomePath, getWhatsAppUrl, getPhoneUrl } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homePath = getHomePath(lang);
const whatsappUrl = getWhatsAppUrl(lang);
const phoneUrl = getPhoneUrl();

const navLinks = [
  { key: "nav.rooms" as const, route: "rooms" },
  { key: "nav.experience" as const, route: "experience" },
  { key: "nav.cunda" as const, route: "guide" },
  { key: "nav.gallery" as const, route: "gallery" },
  { key: "nav.contact" as const, route: "contact" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-400" role="contentinfo">

  <!-- ─── Main Footer ─── -->
  <div class="container-wide py-16 lg:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">

      <!-- Brand Column -->
      <div class="lg:col-span-5">
        <a href={homePath} class="inline-block mb-6 group">
          <span class="block font-serif text-xl text-stone-100 tracking-wide">MILOS</span>
          <span class="block font-sans text-[0.6rem] font-medium tracking-[0.35em] uppercase text-stone-500 mt-0.5 group-hover:text-stone-300 transition-colors duration-200">
            CUNDA
          </span>
        </a>
        <p class="text-sm leading-relaxed max-w-sm mb-8">
          {t("footer.description")}
        </p>

        <!-- Contact Details (structured for SEO) -->
        <address class="not-italic text-sm leading-loose">
          <div class="flex items-start gap-2.5 mb-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-stone-500">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
            </svg>
            <span>{t("footer.tagline")}</span>
          </div>
          <div class="flex items-center gap-2.5 mb-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-stone-500">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            <a href={phoneUrl} class="hover:text-stone-200 transition-colors duration-200">
              +90 5XX XXX XXXX
            </a>
          </div>
          <div class="flex items-center gap-2.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-stone-500">
              <rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
            <a href="mailto:info@miloscunda.com" class="hover:text-stone-200 transition-colors duration-200">
              info@miloscunda.com
            </a>
          </div>
        </address>
      </div>

      <!-- Navigation Column -->
      <div class="lg:col-span-3 lg:col-start-7">
        <h4 class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-stone-500 mb-6">
          {t("footer.navigation")}
        </h4>
        <nav class="flex flex-col gap-3" aria-label="Footer navigation">
          {navLinks.map(({ key, route }) => (
            <a
              href={getLocalizedPath(lang, route)}
              class="text-sm text-stone-400 hover:text-stone-100 transition-colors duration-200"
            >
              {t(key)}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social + CTA Column -->
      <div class="lg:col-span-4">
        <h4 class="text-[0.65rem] font-medium tracking-[0.25em] uppercase text-stone-500 mb-6">
          {t("footer.followUs")}
        </h4>
        <div class="flex items-center gap-4 mb-10">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/miloscunda"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-stone-700
                   text-stone-400 hover:text-stone-50 hover:border-stone-400 transition-all duration-200"
            aria-label="Instagram"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/miloscunda"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-stone-700
                   text-stone-400 hover:text-stone-50 hover:border-stone-400 transition-all duration-200"
            aria-label="Facebook"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-stone-700
                   text-stone-400 hover:text-stone-50 hover:border-stone-400 transition-all duration-200"
            aria-label="WhatsApp"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
            </svg>
          </a>
        </div>

        <!-- CTA Block -->
        <div class="border border-stone-800 rounded-[2px] p-6">
          <p class="text-stone-300 text-sm font-medium mb-1">{t("cta.whatsapp")}</p>
          <p class="text-stone-500 text-xs leading-relaxed mb-4">{t("hero.subtitle")}</p>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.15em]
                   uppercase text-olive-400 hover:text-olive-300 transition-colors duration-200"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
            </svg>
            {t("header.reserve")}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- ─── Bottom Bar ─── -->
  <div class="border-t border-stone-800">
    <div class="container-wide py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-stone-600 text-xs tracking-wide">
        &copy; {currentYear} Milos Cunda. {t("footer.rights")}
      </p>
      <div class="flex items-center gap-5">
        <a href={`/${lang}/`} class="text-stone-600 hover:text-stone-400 text-xs tracking-wide transition-colors duration-200">
          {t("footer.privacy")}
        </a>
        <span class="text-stone-700 text-[0.5rem] select-none">&middot;</span>
        <span class="text-stone-700 text-[0.6rem] tracking-[0.2em] font-mono">
          39.33°N 26.69°E
        </span>
      </div>
    </div>
  </div>
</footer>
