---
/**
 * Milos Cunda — Hero Section
 *
 * Full-viewport cinematic hero with:
 * - Autoplay muted background video (drone footage)
 * - Warm gradient overlay + grain texture
 * - Staggered entrance: accent line → tagline → subtitle → CTAs → scroll hint
 * - Left-aligned editorial layout (desktop) / centered (mobile)
 * - Location tag in the corner for boutique hotel feel
 *
 * Zero client JS. Pure CSS animations with animation-delay staggering.
 */

import { getLangFromUrl, useTranslations, getLocalizedPath, getWhatsAppUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const whatsappUrl = getWhatsAppUrl(lang);
const roomsPath = getLocalizedPath(lang, "rooms");
---

<section
  class="relative w-full h-svh min-h-[600px] max-h-[1200px] flex items-end overflow-hidden"
  aria-label={t("hero.videoLabel")}
>
  <!-- ─── Background Video ─── -->
  <video
    class="absolute inset-0 w-full h-full object-cover img-warm"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/images/hero-poster.jpg"
  >
    <source src="/videos/hero-placeholder.mp4" type="video/mp4" />
  </video>

  <!-- ─── Overlay Stack ─── -->
  <!-- 1. Base warm tint -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(23,20,18,0.15) 0%, rgba(23,20,18,0.25) 40%, rgba(23,20,18,0.65) 100%);"
    aria-hidden="true"
  ></div>

  <!-- 2. Horizontal gradient for left-side text readability (desktop) -->
  <div
    class="absolute inset-0 hidden lg:block"
    style="background: linear-gradient(90deg, rgba(23,20,18,0.35) 0%, rgba(23,20,18,0.05) 60%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <!-- 3. Grain texture -->
  <div class="absolute inset-0 grain" aria-hidden="true"></div>

  <!-- ─── Location Badge (top-right corner) ─── -->
  <div
    class="absolute top-28 lg:top-32 right-[var(--spacing-gutter)]
           hidden md:flex items-center gap-2 hero-stagger-5"
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-stone-300/80">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
      <circle cx="12" cy="10" r="3" />
    </svg>
    <span class="text-stone-300/80 text-[0.65rem] tracking-[0.3em] uppercase font-medium">
      39.33°N &nbsp; 26.69°E
    </span>
  </div>

  <!-- ─── Hero Content ─── -->
  <div class="relative z-10 container-wide pb-20 sm:pb-24 lg:pb-32">
    <div class="max-w-2xl lg:max-w-3xl">

      <!-- Accent Line -->
      <div
        class="hero-stagger-1 h-px bg-olive-400/70 mb-8"
        aria-hidden="true"
      ></div>

      <!-- Tagline -->
      <h1 class="hero-stagger-2 text-display text-stone-50 mb-5 lg:mb-6">
        {t("hero.tagline")}
      </h1>

      <!-- Subtitle -->
      <p class="hero-stagger-3 text-lg sm:text-xl text-stone-200/90 font-light max-w-md lg:max-w-lg leading-relaxed mb-10 lg:mb-14">
        {t("hero.subtitle")}
      </p>

      <!-- CTAs -->
      <div class="hero-stagger-4 flex flex-wrap items-center gap-5 sm:gap-7">

        <!-- Primary CTA: Explore Rooms -->
        <a href={roomsPath} class="btn-primary">
          <span>{t("cta.allRooms")}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>

        <!-- Secondary CTA: WhatsApp -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          <span>{t("cta.whatsapp")}</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-arrow shrink-0">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- ─── Scroll Indicator ─── -->
  <div
    class="hero-stagger-5 absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3"
    aria-hidden="true"
  >
    <span class="text-stone-300/60 text-[0.6rem] tracking-[0.35em] uppercase font-medium">
      {t("hero.scroll")}
    </span>
    <div
      class="w-px h-8 bg-gradient-to-b from-stone-300/50 to-transparent"
      style="animation: scroll-hint-bob 2.4s ease-in-out infinite;"
    ></div>
  </div>
</section>
