---
/**
 * Milos Cunda — Header (v2)
 *
 * STATE MANAGEMENT: Uses data-* attributes instead of CSS classes.
 * This bypasses Tailwind v4's @layer specificity issues entirely.
 *
 * [data-header]                    → transparent state (default)
 * [data-header][data-scrolled]     → frosted glass state
 * [data-mobile-menu]               → hidden (default)
 * [data-mobile-menu][data-open]    → visible full-screen overlay
 * [data-hamburger][aria-expanded]  → X morphing via aria state
 */

import { getLangFromUrl, useTranslations, getLocalizedPath, getHomePath, getWhatsAppUrl } from "../i18n/utils";
import { languages, type Lang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { key: "nav.rooms" as const, route: "rooms" },
  { key: "nav.experience" as const, route: "experience" },
  { key: "nav.cunda" as const, route: "guide" },
  { key: "nav.gallery" as const, route: "gallery" },
  { key: "nav.contact" as const, route: "contact" },
];

const whatsappUrl = getWhatsAppUrl(lang);
const homePath = getHomePath(lang);

const langOptions = (Object.keys(languages) as Lang[]).map((l) => ({
  code: l,
  label: l.toUpperCase(),
  href: Astro.url.pathname.replace(new RegExp(`^/${lang}`), `/${l}`),
  isCurrent: l === lang,
}));
---

<!-- ══════════════ HEADER ══════════════ -->
<header data-header role="banner">
  <div class="container-wide">
    <div class="flex items-center justify-between h-20 lg:h-24">

      <!-- Logo -->
      <a
        href={homePath}
        class="relative z-10 flex flex-col items-start leading-none group shrink-0"
        aria-label="Milos Cunda — Home"
      >
        <span class="logo-text font-serif text-xl lg:text-2xl font-medium tracking-wide transition-colors duration-300">
          MILOS
        </span>
        <span class="logo-text font-sans text-[0.6rem] lg:text-[0.65rem] font-medium tracking-[0.35em] uppercase transition-colors duration-300 mt-0.5 opacity-70 group-hover:opacity-100">
          CUNDA
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-10" aria-label="Main navigation">
        {navItems.map(({ key, route }) => (
          <a
            href={getLocalizedPath(lang, route)}
            class="hdr-link text-[0.7rem] font-medium tracking-[0.2em] uppercase"
          >
            {t(key)}
          </a>
        ))}
      </nav>

      <!-- Right: Lang + Reserve + Hamburger -->
      <div class="flex items-center gap-5 lg:gap-6 shrink-0">

        <!-- Language Switcher (desktop + tablet) -->
        <nav class="hidden md:flex items-center gap-1.5" aria-label={t("header.langLabel")}>
          {langOptions.map((opt, i) => (
            <>
              <a
                href={opt.href}
                class:list={[
                  "hdr-link text-[0.65rem] tracking-[0.2em] uppercase transition-colors duration-200",
                  opt.isCurrent ? "font-semibold !opacity-100" : "font-normal opacity-40 hover:opacity-90",
                ]}
                aria-current={opt.isCurrent ? "page" : undefined}
              >
                {opt.label}
              </a>
              {i < langOptions.length - 1 && (
                <span class="hdr-link text-[0.45rem] opacity-25 select-none">&middot;</span>
              )}
            </>
          ))}
        </nav>

        <!-- Reserve CTA (desktop) -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="reserve-btn hidden lg:inline-flex items-center gap-2 text-[0.65rem]
                 font-medium tracking-[0.18em] uppercase border rounded-[2px] px-5 py-2.5
                 transition-all duration-300"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          {t("header.reserve")}
        </a>

        <!-- Hamburger (mobile/tablet) -->
        <button
          data-hamburger
          class="relative z-[350] lg:hidden"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label={t("a11y.menuOpen")}
        >
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- ══════════════ MOBILE MENU ══════════════ -->
<div
  id="mobile-menu"
  data-mobile-menu
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <nav class="flex flex-col items-center" aria-label="Mobile navigation">
    {navItems.map(({ key, route }) => (
      <a href={getLocalizedPath(lang, route)} class="mob-link">
        {t(key)}
      </a>
    ))}
  </nav>

  <!-- Mobile Language Switcher -->
  <div class="mt-12 flex items-center gap-3">
    {langOptions.map((opt, i) => (
      <>
        <a
          href={opt.href}
          class:list={[
            "text-xs tracking-[0.25em] uppercase transition-colors duration-200",
            opt.isCurrent ? "text-stone-50 font-semibold" : "text-stone-500 hover:text-stone-200",
          ]}
        >
          {opt.label}
        </a>
        {i < langOptions.length - 1 && (
          <span class="text-stone-700 text-[0.5rem] select-none">&middot;</span>
        )}
      </>
    ))}
  </div>

  <!-- Mobile WhatsApp CTA -->
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-10 inline-flex items-center gap-2.5 text-xs font-medium tracking-[0.18em] uppercase
           text-stone-400 hover:text-stone-50 transition-colors duration-200
           border border-stone-700 hover:border-stone-400 rounded-[2px] px-7 py-3"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    {t("cta.whatsapp")}
  </a>
</div>

<!-- ══════════════ SCRIPT ══════════════ -->
<script>
  document.addEventListener("astro:page-load", () => {
    const header = document.querySelector("[data-header]");
    const hamburger = document.querySelector("[data-hamburger]");
    const menu = document.querySelector("[data-mobile-menu]");
    if (!header || !hamburger || !menu) return;

    // ── Scroll state ──
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          if (window.scrollY > 50) {
            header.setAttribute("data-scrolled", "");
          } else {
            header.removeAttribute("data-scrolled");
          }
          ticking = false;
        });
        ticking = true;
      }
    }
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // ── Mobile menu ──
    let open = false;
    function toggle() {
      open = !open;
      hamburger.setAttribute("aria-expanded", String(open));
      if (open) {
        menu.setAttribute("data-open", "");
      } else {
        menu.removeAttribute("data-open");
      }
      document.body.style.overflow = open ? "hidden" : "";
    }

    hamburger.addEventListener("click", toggle);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && open) toggle(); });
    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => { if (open) toggle(); }));
  });
</script>
