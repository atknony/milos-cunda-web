---
/**
 * Milos Cunda — Room Detail Page
 * Route: /[lang]/rooms/[slug]
 *
 * Editorial magazine layout:
 * 1. Cinematic hero image (65vh) with title + price overlay
 * 2. Horizontal spec bar (guests, size, bed, view, check-in/out)
 * 3. Two-column: description + amenities | gallery mosaic
 * 4. Full-width booking CTA (WhatsApp + Call)
 * 5. Other rooms carousel
 */

import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import MainLayout from "../../../layouts/MainLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import Lightbox from "../../../components/Lightbox.astro";

import { languages, type Lang } from "../../../i18n/ui";
import {
  useTranslations,
  getLocalizedPath,
  getWhatsAppUrl,
  getPhoneUrl,
} from "../../../i18n/utils";
import { generateRoomSchema } from "../../../lib/schema";

/* ─── Static Paths ─── */
export const getStaticPaths = (async () => {
  const allRooms = await getCollection("rooms");
  const langs = Object.keys(languages) as Lang[];

  return langs.flatMap((lang) =>
    allRooms
      .filter((r) => r.data.isPublished)
      .map((room) => ({
        params: { lang, slug: room.data.slug },
        props: { room },
      }))
  );
}) satisfies GetStaticPaths;

/* ─── Page Setup ─── */
const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { room } = Astro.props;
const d = room.data;
const t = useTranslations(lang);

/* ─── Localized Data ─── */
const title = d.title[lang];
const tagline = d.tagline?.[lang];
const description = d.description[lang];
const bedType = d.bedType[lang];
const view = d.view?.[lang];
const totalGuests = d.capacity.adults + d.capacity.children;

const whatsappUrl = getWhatsAppUrl(lang, title);
const phoneUrl = getPhoneUrl();
const roomsListUrl = getLocalizedPath(lang, "rooms");

/* ─── Currency Symbol ─── */
const currencySymbol = d.priceHint?.currency === "EUR" ? "€"
  : d.priceHint?.currency === "USD" ? "$" : "₺";

/* ─── All Gallery Images (featured + gallery) ─── */
const allImages = [d.featuredImage, ...d.gallery];

/* ─── Other Rooms ─── */
const allRooms = await getCollection("rooms");
const otherRooms = allRooms
  .filter((r) => r.data.isPublished && r.data.slug !== slug)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

/* ─── SEO ─── */
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://miloscunda.com";
const breadcrumbs = [
  { name: "Milos Cunda", url: `${siteUrl}/${lang}/` },
  { name: t("rooms.title"), url: `${siteUrl}${roomsListUrl}` },
  { name: title, url: `${siteUrl}${getLocalizedPath(lang, "rooms", slug)}` },
];

const roomSchema = generateRoomSchema(lang, {
  slug: d.slug,
  name: title,
  description,
  image: d.featuredImage.src,
  gallery: d.gallery.map((g) => g.src),
  occupancy: d.capacity,
  size: d.size,
  bedType,
  amenities: d.amenities.map((a) => a.label[lang]),
  priceHint: d.priceHint
    ? { amount: d.priceHint.amount, currency: d.priceHint.currency }
    : undefined,
});

const pageTitle = `${title} | Milos Cunda`;
const pageDesc = d.seo?.description?.[lang] ?? description.slice(0, 155);
---

<MainLayout
  title={pageTitle}
  description={pageDesc}
  ogImage={d.featuredImage.src}
  breadcrumbs={breadcrumbs}
  additionalSchemas={[roomSchema]}
>
  <Header slot="header" />

  <!-- ═══════════════════════════════════════
       1. ROOM HERO
       ═══════════════════════════════════════ -->
  <section class="room-hero">
    <img
      src={d.featuredImage.src}
      alt={d.featuredImage.alt[lang]}
      width={d.featuredImage.width ?? 1600}
      height={d.featuredImage.height ?? 1067}
      loading="eager"
      decoding="async"
    />
    <div class="room-hero-overlay" aria-hidden="true"></div>
    <div class="grain absolute inset-0" aria-hidden="true"></div>

    <!-- Breadcrumb (top-left) -->
    <nav
      class="absolute top-28 lg:top-32 left-[var(--spacing-gutter)] z-10
             flex items-center gap-2 text-[0.6rem] tracking-[0.2em] uppercase
             text-stone-300/70 hero-stagger-5"
      aria-label="Breadcrumb"
    >
      <a href={`/${lang}/`} class="hover:text-stone-50 transition-colors duration-200">Milos</a>
      <span class="opacity-40">/</span>
      <a href={roomsListUrl} class="hover:text-stone-50 transition-colors duration-200">
        {t("rooms.title")}
      </a>
      <span class="opacity-40">/</span>
      <span class="text-stone-100/80">{title}</span>
    </nav>

    <!-- Price Badge (top-right on desktop, bottom-right on mobile) -->
    {d.priceHint && (
      <div class="absolute bottom-24 sm:bottom-auto sm:top-28 lg:top-32 right-[var(--spacing-gutter)] z-10 hero-stagger-5">
        <div class="bg-stone-950/40 backdrop-blur-sm rounded-[2px] px-4 py-2.5 sm:px-5 sm:py-3 text-stone-50 text-right">
          <span class="block text-[0.55rem] sm:text-[0.6rem] tracking-[0.2em] uppercase opacity-60 mb-0.5">
            {t("room.startingFrom")}
          </span>
          <span class="block font-serif text-xl sm:text-2xl font-medium leading-tight">
            {currencySymbol}{d.priceHint.amount}
          </span>
          <span class="block text-[0.55rem] sm:text-[0.6rem] opacity-50 mt-0.5">/ {t("room.from")}</span>
        </div>
      </div>
    )}

    <!-- Title Block (bottom-left) -->
    <div class="absolute bottom-0 left-0 right-0 z-10 container-wide pb-10 lg:pb-14">
      <div class="max-w-2xl">
        {tagline && (
          <p class="hero-stagger-1 text-stone-300/80 text-[0.7rem] tracking-[0.25em] uppercase font-medium mb-3">
            {tagline}
          </p>
        )}
        <h1 class="hero-stagger-2 text-stone-50 font-serif font-medium leading-[1.08]"
            style="font-size: clamp(2rem, 4vw + 0.5rem, 4rem);">
          {title}
        </h1>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       2. SPECS BAR
       ═══════════════════════════════════════ -->
  <section class="bg-stone-50 border-b border-stone-200">
    <div class="container-wide">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 text-center">
        <!-- Guests -->
        <div class="px-4 py-5 flex flex-col items-center gap-1.5
                    border-b sm:border-b-0 border-r border-stone-200">
          <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
            {t("room.capacity")}
          </span>
          <span class="text-sm text-stone-800">
            {t("room.guests", { count: String(totalGuests) })}
          </span>
        </div>
        <!-- Size -->
        <div class="px-4 py-5 flex flex-col items-center gap-1.5
                    border-b sm:border-b-0 border-r-0 sm:border-r border-stone-200">
          <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
            {t("room.size")}
          </span>
          <span class="text-sm text-stone-800">{d.size.value} {d.size.unit}</span>
        </div>
        <!-- Bed -->
        <div class="px-4 py-5 flex flex-col items-center gap-1.5
                    border-b lg:border-b-0 border-r border-stone-200">
          <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
            {t("room.bedType")}
          </span>
          <span class="text-sm text-stone-800">{bedType}</span>
        </div>
        <!-- View -->
        {view && (
          <div class="px-4 py-5 flex flex-col items-center gap-1.5
                      border-b lg:border-b-0 border-r-0 lg:border-r border-stone-200">
            <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
              {t("room.view")}
            </span>
            <span class="text-sm text-stone-800 text-center">{view}</span>
          </div>
        )}
        <!-- Check-in / Check-out -->
        <div class="col-span-2 sm:col-span-1 px-4 py-5 flex flex-col items-center gap-1.5">
          <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
            {t("room.checkIn")}
          </span>
          <span class="text-[0.6rem] tracking-[0.2em] uppercase text-stone-400 font-medium">
            {t("room.checkOut")}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       3. MAIN CONTENT: Description + Gallery
       ═══════════════════════════════════════ -->
  <section class="section-padding bg-stone-50">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 xl:gap-24">

        <!-- LEFT: Description + Amenities (spans 5 cols) -->
        <div class="lg:col-span-5 lg:col-start-1">

          <!-- About -->
          <div class="reveal">
            <div class="line-accent mb-5" aria-hidden="true"></div>
            <h2 class="font-serif text-2xl lg:text-3xl text-stone-900 mb-6">
              {t("room.about")}
            </h2>
            <p class="text-editorial text-stone-600 leading-[1.85]">
              {description}
            </p>
          </div>

          <!-- Amenities -->
          <div class="reveal mt-14 lg:mt-18">
            <h3 class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium mb-5">
              {t("room.amenities")}
            </h3>
            <div class="flex flex-wrap gap-2.5">
              {d.amenities.map((amenity) => (
                <span class="amenity-tag">
                  {/* Minimal SVG icon placeholder — mapped from icon name */}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                       class="text-olive-500 shrink-0">
                    <circle cx="12" cy="12" r="1.5" />
                  </svg>
                  {amenity.label[lang]}
                </span>
              ))}
            </div>
          </div>

          <!-- Room Specs (vertical list) -->
          <div class="reveal mt-14 lg:mt-18">
            <h3 class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium mb-3">
              {t("room.specs")}
            </h3>
            <div>
              <div class="spec-item">
                <span class="spec-label">{t("room.capacity")}</span>
                <span class="spec-value">
                  {d.capacity.adults} {lang === "tr" ? "Yetişkin" : lang === "el" ? "Ενήλικες" : "Adults"}
                  {d.capacity.children > 0 && (
                    <> + {d.capacity.children} {lang === "tr" ? "Çocuk" : lang === "el" ? "Παιδιά" : "Children"}</>
                  )}
                </span>
              </div>
              <div class="spec-item">
                <span class="spec-label">{t("room.size")}</span>
                <span class="spec-value">{d.size.value} m²</span>
              </div>
              <div class="spec-item">
                <span class="spec-label">{t("room.bedType")}</span>
                <span class="spec-value">{bedType}</span>
              </div>
              {view && (
                <div class="spec-item">
                  <span class="spec-label">{t("room.view")}</span>
                  <span class="spec-value">{view}</span>
                </div>
              )}
            </div>
          </div>

          <!-- Inline Booking CTA (mobile-first, visible under specs) -->
          <div class="reveal mt-12 lg:mt-16">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2.5 w-full py-4
                     bg-stone-900 hover:bg-stone-800 text-stone-50
                     text-[0.7rem] font-medium tracking-[0.2em] uppercase
                     rounded-[2px] transition-colors duration-300"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
              </svg>
              {t("room.bookThis")}
            </a>
            <a
              href={phoneUrl}
              class="flex items-center justify-center gap-2 w-full py-3.5 mt-3
                     text-stone-500 hover:text-stone-800 text-[0.7rem] font-medium
                     tracking-[0.2em] uppercase border border-stone-200
                     hover:border-stone-400 rounded-[2px] transition-all duration-300"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              {t("cta.call")}
            </a>
          </div>
        </div>

        <!-- RIGHT: Gallery Mosaic (spans 7 cols) -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium">
                {t("room.gallery")}
              </span>
              <span class="text-stone-300 text-xs">
                {t("lightbox.counter", {
                  current: "1",
                  total: String(allImages.length),
                })}
              </span>
            </div>
          </div>

          <!-- Mosaic Grid -->
          <div class="gallery-mosaic reveal">
            {allImages.map((img, i) => (
              <div
                class:list={[
                  "gallery-mosaic-item",
                  i === 0 ? "aspect-[16/10]" : "aspect-[4/3]",
                ]}
              >
                <img
                  src={img.src}
                  alt={img.alt[lang]}
                  width={img.width ?? 800}
                  height={img.height ?? 600}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  data-lightbox-trigger
                  data-src={img.src}
                  data-alt={img.alt[lang]}
                />
                {/* First image: gallery count badge */}
                {i === 0 && (
                  <div class="absolute bottom-3 right-3 bg-stone-950/50 backdrop-blur-sm
                              rounded-[2px] px-3 py-1.5 text-stone-200 text-[0.6rem]
                              tracking-[0.2em] uppercase pointer-events-none">
                    {allImages.length} {lang === "tr" ? "fotoğraf" : lang === "el" ? "φωτογραφίες" : "photos"}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       4. OTHER ROOMS
       ═══════════════════════════════════════ -->
  {otherRooms.length > 0 && (
    <section class="py-16 lg:py-24 bg-stone-100/50 overflow-hidden">
      <div class="container-wide">
        <div class="reveal flex items-end justify-between mb-10 lg:mb-14">
          <div>
            <div class="line-accent mb-5" aria-hidden="true"></div>
            <h2 class="font-serif text-2xl lg:text-3xl text-stone-900">
              {t("room.otherRooms")}
            </h2>
          </div>
          <a
            href={roomsListUrl}
            class="hidden sm:inline-flex items-center gap-2 text-[0.65rem] font-medium
                   tracking-[0.2em] uppercase text-stone-500 hover:text-stone-800
                   transition-colors duration-200 group"
          >
            {t("room.backToRooms")}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Horizontal scroll -->
        <div
          class="reveal flex gap-5 overflow-x-auto pb-4
                 -mx-[var(--spacing-gutter)] px-[var(--spacing-gutter)]
                 snap-x snap-mandatory overscroll-x-contain"
        >
          {otherRooms.map((other) => (
            <a
              href={getLocalizedPath(lang, "rooms", other.data.slug)}
              class="other-room-card snap-start group"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={other.data.featuredImage.src}
                  alt={other.data.featuredImage.alt[lang]}
                  width="560"
                  height="420"
                  loading="lazy"
                  decoding="async"
                  class="img-cover img-warm"
                />
              </div>
              <div class="p-4">
                <h3 class="font-serif text-lg text-stone-900 group-hover:text-aegean-700
                           transition-colors duration-200 mb-0.5">
                  {other.data.title[lang]}
                </h3>
                {other.data.tagline && (
                  <p class="text-stone-400 text-sm italic mb-2">
                    {other.data.tagline[lang]}
                  </p>
                )}
                <div class="flex items-center gap-3 text-stone-500 text-xs">
                  <span>{other.data.size.value} m²</span>
                  <span class="text-stone-300">·</span>
                  <span>{t("room.guests", { count: String(other.data.capacity.adults + other.data.capacity.children) })}</span>
                  {other.data.priceHint && (
                    <>
                      <span class="text-stone-300">·</span>
                      <span class="font-medium text-stone-700">
                        {other.data.priceHint.currency === "EUR" ? "€" : other.data.priceHint.currency === "USD" ? "$" : "₺"}{other.data.priceHint.amount}
                      </span>
                    </>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Mobile "all rooms" link -->
        <div class="sm:hidden mt-8 text-center">
          <a
            href={roomsListUrl}
            class="inline-flex items-center gap-2 text-[0.7rem] font-medium
                   tracking-[0.2em] uppercase text-stone-600 hover:text-stone-900
                   transition-colors duration-200 group"
          >
            {t("room.backToRooms")}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" />
  <Lightbox />
</MainLayout>
