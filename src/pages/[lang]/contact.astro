---
/**
 * Milos Cunda — Contact Page
 * Route: /[lang]/contact/
 *
 * Split-screen editorial layout:
 * 1. Page header with tagline
 * 2. Two-column: Left (directions prose + embedded map) | Right (contact cards + social)
 * 3. Full-width booking CTA banner
 *
 * No contact form — CTA priority is WhatsApp and Direct Calls.
 */

import type { GetStaticPaths } from "astro";
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

import { languages, type Lang } from "../../i18n/ui";
import {
  useTranslations,
  getLocalizedPath,
  getWhatsAppUrl,
  getPhoneUrl,
} from "../../i18n/utils";

export const getStaticPaths = (() => {
  return (Object.keys(languages) as Lang[]).map((lang) => ({
    params: { lang },
  }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const whatsappUrl = getWhatsAppUrl(lang);
const phoneUrl = getPhoneUrl();

const COORDINATES = { lat: 39.3275, lng: 26.6927 };
const mapsUrl = `https://www.google.com/maps?q=${COORDINATES.lat},${COORDINATES.lng}`;
const embedUrl = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3095.0!2d${COORDINATES.lng}!3d${COORDINATES.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMznCsDE5JzM5LjAiTiAyNsKwNDEnMzMuNyJF!5e0!3m2!1str!2str!4v1`;

/* ─── SEO ─── */
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://miloscunda.com";
const breadcrumbs = [
  { name: "Milos Cunda", url: `${siteUrl}/${lang}/` },
  { name: t("contact.title"), url: `${siteUrl}${getLocalizedPath(lang, "contact")}` },
];
---

<MainLayout
  title={`${t("contact.title")} | Milos Cunda`}
  description={t("contact.subtitle")}
  breadcrumbs={breadcrumbs}
>
  <Header slot="header" />

  <!-- ═══════════════════════════════════════
       1. PAGE HEADER
       ═══════════════════════════════════════ -->
  <section class="pt-32 lg:pt-40 pb-12 lg:pb-16 bg-stone-50">
    <div class="container-narrow text-center">
      <div class="line-accent mx-auto mb-6 hero-stagger-1" aria-hidden="true"></div>
      <h1 class="text-display text-stone-900 mb-4 hero-stagger-2">
        {t("contact.title")}
      </h1>
      <p class="text-stone-500 text-base sm:text-lg leading-relaxed max-w-md mx-auto hero-stagger-3">
        {t("contact.subtitle")}
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       2. MAIN CONTENT: Map + Contact
       ═══════════════════════════════════════ -->
  <section class="section-padding bg-stone-50 pt-0">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

        <!-- LEFT: Directions + Map (7 cols) -->
        <div class="lg:col-span-7">

          <!-- Directions -->
          <div class="reveal mb-10 lg:mb-14">
            <div class="line-accent mb-5" aria-hidden="true"></div>
            <h2 class="font-serif text-2xl lg:text-3xl text-stone-900 mb-5">
              {t("contact.directions")}
            </h2>
            <p class="text-editorial text-stone-600 leading-[1.85]">
              {t("contact.directionsDesc")}
            </p>
          </div>

          <!-- Map Embed -->
          <div class="reveal map-frame">
            <iframe
              src={embedUrl}
              width="100%"
              height="100%"
              style="border:0; position: absolute; inset: 0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={t("contact.mapLabel")}
            ></iframe>
          </div>

          <!-- "View on Google Maps" link -->
          <div class="reveal mt-4">
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.18em]
                     uppercase text-stone-500 hover:text-stone-800 transition-colors duration-200 group"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              {t("contact.mapLabel")}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </a>
          </div>

          <!-- GPS Coordinates -->
          <div class="reveal mt-6 flex items-center gap-2">
            <span class="text-stone-300 text-[0.6rem] tracking-[0.3em] font-mono uppercase">
              {COORDINATES.lat}°N &nbsp; {COORDINATES.lng}°E
            </span>
          </div>
        </div>

        <!-- RIGHT: Contact Cards (5 cols) -->
        <div class="lg:col-span-5">

          <!-- Contact Details -->
          <div class="reveal">
            <h2 class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium mb-2">
              {t("footer.contact")}
            </h2>

            <!-- Address -->
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div>
                <span class="spec-label">{t("contact.address")}</span>
                <address class="not-italic text-sm text-stone-700 leading-relaxed mt-1">
                  Sahil Mahallesi, Namık Kemal Caddesi No:XX<br />
                  {t("footer.tagline")}
                </address>
              </div>
            </div>

            <!-- Phone -->
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <div>
                <span class="spec-label">{t("contact.phone")}</span>
                <a href={phoneUrl}
                   class="block text-sm text-stone-700 hover:text-stone-900 transition-colors duration-200 mt-1">
                  +90 5XX XXX XXXX
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                </svg>
              </div>
              <div>
                <span class="spec-label">WhatsApp</span>
                <a href={whatsappUrl}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="block text-sm text-stone-700 hover:text-stone-900 transition-colors duration-200 mt-1">
                  {t("cta.whatsapp")}
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              </div>
              <div>
                <span class="spec-label">{t("contact.email")}</span>
                <a href="mailto:info@miloscunda.com"
                   class="block text-sm text-stone-700 hover:text-stone-900 transition-colors duration-200 mt-1">
                  info@miloscunda.com
                </a>
              </div>
            </div>

            <!-- Reception Hours -->
            <div class="contact-item">
              <div class="contact-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </div>
              <div>
                <span class="spec-label">{t("contact.hours")}</span>
                <span class="block text-sm text-stone-700 mt-1">
                  {t("contact.hoursValue")}
                </span>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="reveal mt-10" style="transition-delay: 0.1s">
            <h3 class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium mb-5">
              {t("footer.followUs")}
            </h3>
            <div class="flex items-center gap-3">
              <a
                href="https://www.instagram.com/miloscunda"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 flex items-center justify-center rounded-full
                       border border-stone-200 text-stone-400
                       hover:text-stone-800 hover:border-stone-400
                       transition-all duration-200"
                aria-label="Instagram"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                </svg>
              </a>
              <a
                href="https://www.facebook.com/miloscunda"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 flex items-center justify-center rounded-full
                       border border-stone-200 text-stone-400
                       hover:text-stone-800 hover:border-stone-400
                       transition-all duration-200"
                aria-label="Facebook"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              </a>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 flex items-center justify-center rounded-full
                       border border-stone-200 text-stone-400
                       hover:text-stone-800 hover:border-stone-400
                       transition-all duration-200"
                aria-label="WhatsApp"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Primary CTA Card -->
          <div class="reveal mt-10 bg-stone-900 rounded-sm p-7 lg:p-9" style="transition-delay: 0.15s">
            <h3 class="font-serif text-xl text-stone-50 mb-2">
              {t("hero.tagline")}
            </h3>
            <p class="text-stone-400 text-sm leading-relaxed mb-6">
              {t("hero.subtitle")}
            </p>
            <div class="flex flex-col gap-3">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2.5 py-3.5
                       bg-stone-50 hover:bg-white text-stone-900
                       text-[0.7rem] font-medium tracking-[0.18em] uppercase
                       rounded-[2px] transition-colors duration-300"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                </svg>
                {t("cta.whatsapp")}
              </a>
              <a
                href={phoneUrl}
                class="flex items-center justify-center gap-2 py-3
                       text-stone-400 hover:text-stone-50
                       text-[0.7rem] font-medium tracking-[0.18em] uppercase
                       border border-stone-700 hover:border-stone-400
                       rounded-[2px] transition-all duration-300"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                {t("cta.call")}
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</MainLayout>
