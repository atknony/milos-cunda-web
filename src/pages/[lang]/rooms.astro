---
/**
 * Milos Cunda — Rooms & Suites Listing
 * Route: /[lang]/rooms/ (en), /[lang]/odalar/ (tr), /[lang]/domatia/ (el)
 *
 * Loads all published rooms from the content collection.
 * Renders as a responsive grid of RoomCard components.
 * Includes Lightbox for gallery image viewing.
 */

import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import RoomCard from "../../components/RoomCard.astro";
import Lightbox from "../../components/Lightbox.astro";

import { languages, type Lang } from "../../i18n/ui";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";
import { generateItemListSchema } from "../../lib/schema";

/* ─── Static Paths ─── */
export const getStaticPaths = (() => {
  return (Object.keys(languages) as Lang[]).map((lang) => ({
    params: { lang },
  }));
}) satisfies GetStaticPaths;

/* ─── Page Setup ─── */
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

/* ─── Load Rooms ─── */
const allRooms = await getCollection("rooms");
const rooms = allRooms
  .filter((room) => room.data.isPublished)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

/* ─── SEO ─── */
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://miloscunda.com";
const breadcrumbs = [
  { name: "Milos Cunda", url: `${siteUrl}/${lang}/` },
  { name: t("rooms.title"), url: `${siteUrl}${getLocalizedPath(lang, "rooms")}` },
];

const roomListSchema = generateItemListSchema(
  t("rooms.title"),
  rooms.map((room, i) => ({
    name: room.data.title[lang],
    url: `${siteUrl}${getLocalizedPath(lang, "rooms", room.data.slug)}`,
    image: room.data.featuredImage.src,
    position: i + 1,
  }))
);
---

<MainLayout
  title={`${t("rooms.title")} | Milos Cunda`}
  description={t("rooms.subtitle")}
  breadcrumbs={breadcrumbs}
  additionalSchemas={[roomListSchema]}
>
  <Header slot="header" />

  <!-- ─── Page Header ─── -->
  <section class="pt-32 lg:pt-40 pb-12 lg:pb-16 bg-stone-50">
    <div class="container-narrow text-center">
      <div class="line-accent mx-auto mb-6 hero-stagger-1" aria-hidden="true"></div>
      <h1 class="text-display text-stone-900 mb-4 hero-stagger-2">
        {t("rooms.title")}
      </h1>
      <p class="text-stone-500 text-base sm:text-lg leading-relaxed max-w-lg mx-auto hero-stagger-3">
        {t("rooms.subtitle")}
      </p>
    </div>
  </section>

  <!-- ─── Room Grid ─── -->
  <section class="section-padding bg-stone-50 pt-4">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-14 lg:gap-x-10 lg:gap-y-20">
        {rooms.map((room, i) => (
          <RoomCard
            lang={lang}
            slug={room.data.slug}
            title={room.data.title[lang]}
            tagline={room.data.tagline?.[lang]}
            featuredImage={{
              src: room.data.featuredImage.src,
              alt: room.data.featuredImage.alt[lang],
            }}
            capacity={room.data.capacity}
            size={room.data.size}
            bedType={room.data.bedType[lang]}
            view={room.data.view?.[lang]}
            priceHint={room.data.priceHint}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Gallery Strip ─── -->
  <section class="py-12 lg:py-20 bg-stone-100/40">
    <div class="container-wide">
      <div class="flex items-center gap-3 mb-8">
        <div class="line-accent" aria-hidden="true"></div>
        <span class="text-stone-500 text-[0.7rem] tracking-[0.25em] uppercase font-medium">
          {t("nav.gallery")}
        </span>
      </div>

      <!-- Horizontal scrolling gallery of all room images -->
      <div class="flex gap-3 overflow-x-auto pb-4 -mx-[var(--spacing-gutter)] px-[var(--spacing-gutter)]
                  snap-x snap-mandatory overscroll-x-contain"
      >
        {rooms.flatMap((room) =>
          room.data.gallery.map((img) => (
            <div class="shrink-0 w-64 sm:w-72 lg:w-80 snap-start">
              <div class="aspect-[4/3] overflow-hidden rounded-sm">
                <img
                  src={img.src}
                  alt={img.alt[lang]}
                  width="640"
                  height="480"
                  loading="lazy"
                  decoding="async"
                  data-lightbox-trigger
                  data-src={img.src}
                  data-alt={img.alt[lang]}
                  class="img-cover img-warm hover:scale-105 transition-transform duration-700 cursor-pointer"
                />
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  </section>

  <!-- ─── WhatsApp CTA Banner ─── -->
  <section class="bg-stone-900 text-stone-50 py-16 lg:py-20">
    <div class="container-narrow text-center">
      <div class="reveal">
        <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl mb-3">
          {t("hero.tagline")}
        </h2>
        <p class="text-stone-400 text-base mb-8 max-w-md mx-auto">
          {t("hero.subtitle")}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-5">
          <a
            href={`https://wa.me/905XXXXXXXXX?text=${encodeURIComponent(t("whatsapp.message"))}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 px-7 py-3.5 text-xs font-medium
                   tracking-[0.18em] uppercase border border-stone-600
                   hover:border-stone-300 hover:bg-stone-800 rounded-[2px]
                   transition-all duration-300"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
            </svg>
            {t("cta.whatsapp")}
          </a>
          <a
            href="tel:+905XXXXXXXXX"
            class="inline-flex items-center gap-2 text-xs font-medium tracking-[0.18em]
                   uppercase text-stone-400 hover:text-stone-100 transition-colors duration-200"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            {t("cta.call")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <Lightbox />
</MainLayout>
