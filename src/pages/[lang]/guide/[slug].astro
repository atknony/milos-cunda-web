---
/**
 * Milos Cunda — Guide Article Detail
 * Route: /[lang]/guide/[slug]
 *
 * Long-form editorial layout:
 * 1. Hero image with category badge + title
 * 2. Meta bar (author, date, reading time)
 * 3. Two-column: prose (wide) | sidebar (related entities, booking CTA)
 * 4. Article JSON-LD with Schema.org mentions
 */

import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import MainLayout from "../../../layouts/MainLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

import { languages, type Lang } from "../../../i18n/ui";
import {
  useTranslations,
  getLocalizedPath,
  getWhatsAppUrl,
} from "../../../i18n/utils";
import { generateArticleSchema, generateStandaloneEntitiesFromArticle, generateFAQSchema } from "../../../lib/schema";

/* ─── Static Paths ─── */
export const getStaticPaths = (async () => {
  const allGuides = await getCollection("guides");
  const langs = Object.keys(languages) as Lang[];

  return langs.flatMap((lang) =>
    allGuides
      .filter((g) => g.data.lang === lang && g.data.isPublished)
      .map((guide) => ({
        params: { lang, slug: guide.data.urlSlug },
        props: { guide },
      }))
  );
}) satisfies GetStaticPaths;

/* ─── Page Setup ─── */
const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { guide } = Astro.props;
const d = guide.data;
const t = useTranslations(lang);

/* Render MDX body */
const { Content } = await render(guide);

/* Reading time */
const words = (guide.body ?? "").trim().split(/\s+/).length;
const readMin = Math.max(1, Math.ceil(words / 200));

/* Date formatting */
const dateFormatter = new Intl.DateTimeFormat(
  lang === "tr" ? "tr-TR" : lang === "el" ? "el-GR" : "en-US",
  { year: "numeric", month: "long", day: "numeric" }
);
const publishDate = dateFormatter.format(d.publishedAt);

const whatsappUrl = getWhatsAppUrl(lang);
const guideListUrl = getLocalizedPath(lang, "guide");

/* ─── Other articles (same language, different slug) ─── */
const allGuides = await getCollection("guides");
const otherArticles = allGuides
  .filter((g) => g.data.lang === lang && g.data.isPublished && g.data.urlSlug !== slug)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 2);

/* ─── SEO ─── */
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://miloscunda.com";
const breadcrumbs = [
  { name: "Milos Cunda", url: `${siteUrl}/${lang}/` },
  { name: t("guide.title"), url: `${siteUrl}${guideListUrl}` },
  { name: d.title, url: `${siteUrl}${getLocalizedPath(lang, "guide", slug)}` },
];

const articleSchema = generateArticleSchema(lang, {
  slug: d.urlSlug,
  title: d.title,
  excerpt: d.excerpt,
  image: d.featuredImage.src,
  author: d.author,
  publishedAt: d.publishedAt.toISOString(),
  updatedAt: d.updatedAt?.toISOString(),
  relatedEntities: d.relatedEntities?.map((e) => ({
    name: e.name,
    type: e.type,
    sameAs: e.sameAs,
  })),
});

/* Standalone entity schemas — each relatedEntity gets its own JSON-LD block */
const standaloneEntities = generateStandaloneEntitiesFromArticle(
  lang,
  d.urlSlug,
  d.relatedEntities?.map((e) => ({
    name: e.name,
    type: e.type,
    sameAs: e.sameAs,
  }))
);

/* FAQPage schema — parsed from frontmatter faq array */
const faqSchema = d.faq ? generateFAQSchema(d.faq) : null;

/* Combine all schemas */
const pageSchemas = [
  articleSchema,
  ...standaloneEntities,
  ...(faqSchema ? [faqSchema] : []),
];
---

<MainLayout
  title={`${d.title} | Milos Cunda`}
  description={d.excerpt}
  ogImage={d.featuredImage.src}
  ogType="article"
  breadcrumbs={breadcrumbs}
  additionalSchemas={pageSchemas}
>
  <Header slot="header" />

  <!-- ═══════════════════════════════════════
       1. ARTICLE HERO
       ═══════════════════════════════════════ -->
  <section class="room-hero">
    <img
      src={d.featuredImage.src}
      alt={d.featuredImage.alt[lang]}
      width={d.featuredImage.width ?? 1600}
      height={d.featuredImage.height ?? 1067}
      loading="eager"
      decoding="async"
    />
    <div class="room-hero-overlay" aria-hidden="true"></div>
    <div class="grain absolute inset-0" aria-hidden="true"></div>

    <!-- Breadcrumb -->
    <nav
      class="absolute top-28 lg:top-32 left-[var(--spacing-gutter)] z-10
             flex items-center gap-2 text-[0.6rem] tracking-[0.2em] uppercase
             text-stone-300/70 hero-stagger-5"
      aria-label="Breadcrumb"
    >
      <a href={`/${lang}/`} class="hover:text-stone-50 transition-colors duration-200">Milos</a>
      <span class="opacity-40">/</span>
      <a href={guideListUrl} class="hover:text-stone-50 transition-colors duration-200">
        {t("guide.title")}
      </a>
    </nav>

    <!-- Title Block -->
    <div class="absolute bottom-0 left-0 right-0 z-10 container-wide pb-10 lg:pb-14">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4 hero-stagger-1">
          <span class="cat-badge">{t(`guide.category.${d.category}` as any)}</span>
          <span class="text-stone-300/70 text-[0.65rem] tracking-wider">
            {t("guide.readTime", { min: String(readMin) })}
          </span>
        </div>
        <h1 class="hero-stagger-2 text-stone-50 font-serif font-medium leading-[1.08]"
            style="font-size: clamp(1.75rem, 3.5vw + 0.5rem, 3.5rem);">
          {d.title}
        </h1>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       2. META BAR
       ═══════════════════════════════════════ -->
  <section class="bg-stone-50 border-b border-stone-200">
    <div class="container-wide">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 py-5 text-[0.7rem] tracking-wider text-stone-400">
        {d.author && (
          <span class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
            {d.author}
          </span>
        )}
        <span class="flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
            <line x1="16" x2="16" y1="2" y2="6" /><line x1="8" x2="8" y1="2" y2="6" />
            <line x1="3" x2="21" y1="10" y2="10" />
          </svg>
          {publishDate}
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       3. ARTICLE BODY + SIDEBAR
       ═══════════════════════════════════════ -->
  <section class="section-padding bg-stone-50">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

        <!-- Prose Column -->
        <article class="lg:col-span-8 reveal">
          <div class="prose-guide">
            <Content />
          </div>

          <!-- Article-end CTA -->
          <div class="mt-12 p-5 sm:p-8 lg:p-10 bg-stone-100 rounded-sm border border-stone-200">
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
              <div class="flex-1">
                <h3 class="font-serif text-xl text-stone-900 mb-2">{t("guide.cta.title")}</h3>
                <p class="text-stone-500 text-sm leading-relaxed">{t("guide.cta.text")}</p>
              </div>
              <div class="flex flex-col gap-2.5 shrink-0">
                <a
                  href={`/${lang}/rooms`}
                  class="inline-flex items-center gap-2 px-6 py-3
                         bg-stone-900 hover:bg-stone-800 text-stone-50
                         text-[0.65rem] font-medium tracking-[0.18em] uppercase
                         rounded-[2px] transition-colors duration-300"
                >
                  {t("guide.cta.rooms")}
                </a>
                <a
                  href={whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 px-6 py-2.5
                         text-[0.65rem] font-medium tracking-[0.18em] uppercase
                         text-stone-500 hover:text-stone-800 border border-stone-300
                         hover:border-stone-500 rounded-[2px] transition-all duration-300"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                  </svg>
                  {t("cta.whatsapp")}
                </a>
              </div>
            </div>
          </div>

          <!-- Back to guide -->
          <div class="mt-14 pt-8 border-t border-stone-200">
            <a
              href={guideListUrl}
              class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.18em]
                     uppercase text-stone-500 hover:text-stone-800 transition-colors duration-200 group"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="transition-transform duration-300 group-hover:-translate-x-1">
                <path d="M19 12H5" /><path d="m12 19-7-7 7-7" />
              </svg>
              {t("guide.backToGuide")}
            </a>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-4 reveal" style="transition-delay: 0.15s">

          <!-- Related Entities (GEO enrichment) -->
          {d.relatedEntities && d.relatedEntities.length > 0 && (
            <div class="mb-10">
              <h3 class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium mb-5">
                {t("guide.relatedPlaces")}
              </h3>
              <div class="flex flex-col gap-3">
                {d.relatedEntities.map((entity) => (
                  <div class="flex items-start gap-3 p-4 bg-stone-100 rounded-sm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="mt-0.5 shrink-0 text-olive-500">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    <div>
                      <span class="text-sm text-stone-800 font-medium">{entity.name}</span>
                      <span class="block text-[0.65rem] text-stone-400 tracking-wider uppercase mt-0.5">
                        {entity.type}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Sticky Booking CTA -->
          <div class="lg:sticky lg:top-32">
            <div class="border border-stone-200 rounded-sm p-6 lg:p-8">
              <h3 class="font-serif text-lg text-stone-900 mb-2">
                {t("hero.tagline")}
              </h3>
              <p class="text-stone-500 text-sm leading-relaxed mb-6">
                {t("hero.subtitle")}
              </p>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2.5 w-full py-3.5
                       bg-stone-900 hover:bg-stone-800 text-stone-50
                       text-[0.7rem] font-medium tracking-[0.18em] uppercase
                       rounded-[2px] transition-colors duration-300"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                </svg>
                {t("header.reserve")}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       4. MORE ARTICLES
       ═══════════════════════════════════════ -->
  {otherArticles.length > 0 && (
    <section class="py-16 lg:py-24 bg-stone-100/50">
      <div class="container-wide">
        <div class="reveal flex items-center gap-3 mb-10">
          <div class="line-accent" aria-hidden="true"></div>
          <span class="text-[0.65rem] tracking-[0.25em] uppercase text-stone-400 font-medium">
            {t("guide.readMore")}
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {otherArticles.map((article, i) => (
            <a
              href={getLocalizedPath(lang, "guide", article.data.urlSlug)}
              class="guide-card group reveal"
              style={`transition-delay: ${i * 0.1}s`}
            >
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={article.data.featuredImage.src}
                  alt={article.data.featuredImage.alt[lang]}
                  width="800"
                  height="534"
                  loading="lazy"
                  decoding="async"
                  class="img-cover img-warm"
                />
              </div>
              <div class="p-5 lg:p-6">
                <span class="cat-badge mb-3 inline-block">
                  {t(`guide.category.${article.data.category}` as any)}
                </span>
                <h3 class="font-serif text-lg text-stone-900 mb-2
                           group-hover:text-aegean-700 transition-colors duration-200">
                  {article.data.title}
                </h3>
                <p class="text-stone-500 text-sm leading-relaxed line-clamp-2">
                  {article.data.excerpt}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" />
</MainLayout>
