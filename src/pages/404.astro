---
/**
 * Milos Cunda — 404 Not Found
 *
 * Standalone page (no [lang] param — URL is invalid).
 * Dark cinematic aesthetic with oversized "404" watermark.
 * Offers links home in all three languages + rooms.
 */

import "../styles/global.css";
import { languages, type Lang } from "../i18n/ui";
import { useTranslations, getLocalizedPath } from "../i18n/utils";

/* Default to English for the 404 text since we can't detect language */
const lang: Lang = "en";
const t = useTranslations(lang);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Milos Cunda</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/PlayfairDisplay-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/DMSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="theme-color" content="#171412" />
  </head>

  <body class="bg-stone-950 text-stone-50 font-sans antialiased">
    <div class="four04-bg">

      <!-- Oversized 404 watermark -->
      <div class="four04-number" aria-hidden="true">404</div>

      <!-- Grain texture -->
      <div class="grain absolute inset-0" aria-hidden="true"></div>

      <!-- Content -->
      <div class="relative z-10 px-6 max-w-xl mx-auto">

        <!-- Logo -->
        <a href="/tr/" class="inline-block mb-14 group">
          <span class="block font-serif text-xl tracking-wide text-stone-100">MILOS</span>
          <span class="block font-sans text-[0.6rem] font-medium tracking-[0.35em] uppercase text-stone-500 mt-0.5 group-hover:text-stone-300 transition-colors duration-200">
            CUNDA
          </span>
        </a>

        <!-- Accent line -->
        <div class="w-10 h-px bg-olive-400/50 mb-7 mx-auto hero-stagger-1" aria-hidden="true"></div>

        <!-- Title -->
        <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-medium text-stone-100 mb-4 hero-stagger-2">
          {t("404.title")}
        </h1>

        <!-- Message -->
        <p class="text-stone-400 text-base sm:text-lg leading-relaxed mb-12 max-w-md mx-auto hero-stagger-3">
          {t("404.message")}
        </p>

        <!-- Action Links -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 hero-stagger-4">
          <a
            href="/en/"
            class="inline-flex items-center gap-2.5 px-7 py-3.5
                   bg-stone-50 hover:bg-white text-stone-900
                   text-[0.7rem] font-medium tracking-[0.18em] uppercase
                   rounded-[2px] transition-colors duration-300"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
            {t("404.home")}
          </a>
          <a
            href="/en/rooms"
            class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.18em]
                   uppercase text-stone-400 hover:text-stone-50
                   border border-stone-700 hover:border-stone-400
                   rounded-[2px] px-7 py-3.5 transition-all duration-300"
          >
            {t("404.rooms")}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Language Switcher -->
        <div class="mt-14 flex items-center justify-center gap-4 hero-stagger-5">
          {(Object.keys(languages) as Lang[]).map((l, i) => (
            <>
              <a
                href={`/${l}/`}
                class="text-[0.65rem] tracking-[0.2em] uppercase text-stone-500 hover:text-stone-200 transition-colors duration-200"
              >
                {l.toUpperCase()}
              </a>
              {i < 2 && <span class="text-stone-700 text-[0.45rem] select-none">&middot;</span>}
            </>
          ))}
        </div>

        <!-- Coordinates -->
        <div class="mt-10 hero-stagger-5">
          <span class="text-stone-700 text-[0.55rem] tracking-[0.3em] font-mono uppercase">
            39.33°N &nbsp; 26.69°E
          </span>
        </div>
      </div>
    </div>
  </body>
</html>
